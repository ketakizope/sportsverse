# SportsVerse Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.

# ─── Django Core ───────────────────────────────────────────────────────────────
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here
DEBUG=True

# ─── Allowed Hosts & CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed hostnames (no spaces)
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated list of origins allowed by CORS (for browser clients / web)
# For Flutter mobile you can leave this empty — mobile apps bypass CORS.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Database (MySQL) ──────────────────────────────────────────────────────────
DB_NAME=sportsverse_db
DB_USER=root
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=3306

# ─── Email (Optional — for password reset emails) ──────────────────────────────
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your@email.com
# EMAIL_HOST_PASSWORD=your_email_app_password
# DEFAULT_FROM_EMAIL=noreply@sportsverse.com
